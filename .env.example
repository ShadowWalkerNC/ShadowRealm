# ShadowRealm Network — Orchestrator

# Server port
PORT=4000

# This app's SRN identity
SRN_APP_NAME=shadowrealm

# Shared inter-app secret — ALL SRN apps must share this value
# Generate: node -e "console.log('srn_live_' + require('crypto').randomBytes(32).toString('hex'))"
SRN_SECRET=srn_live_replace_this_with_generated_value

# Optional: override registry app URLs for local dev
# POSTPILOT_URL=http://localhost:5000
# SIGIL_URL=http://localhost:3001
