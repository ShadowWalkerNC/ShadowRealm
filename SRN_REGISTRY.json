          { "method": "POST", "path": "/v1/generate_post",         "auth": true,  "description": "Generate AI caption" },
          { "method": "POST", "path": "/v1/publish_post",          "auth": true,  "description": "Publish to platforms" },
          { "method": "POST", "path": "/v1/generate_and_publish",  "auth": true,  "description": "One-shot generate + publish" },
          { "method": "GET",  "path": "/v1/get_history",           "auth": true,  "description": "Post history" },
          { "method": "GET",  "path": "/v1/get_site_config",       "auth": true,  "description": "Website hub config" },
          { "method": "POST", "path": "/v1/keys/create",           "auth": true,  "description": "Create API key" },
          { "method": "GET",  "path": "/v1/keys",                  "auth": true,  "description": "List API keys" },
          { "method": "DELETE","path": "/v1/keys/<key_id>",        "auth": true,  "description": "Revoke API key" }
        ]
      },
      "env_vars_required": [
        "FLASK_SECRET_KEY",
        "OPENAI_API_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "FACEBOOK_APP_ID",
